{
  "manifest_version": 3,
  "name": "LinkedIn Rich Post",
  "version": "1.0.0",
  "description": "Enhance LinkedIn's post composer with a rich text editor — bold, italic, lists, emojis, and more.",
  "permissions": ["activeTab", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["lib/quill.min.js", "content.js"],
      "css": ["lib/quill.snow.css", "content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/*", "icons/*"],
      "matches": ["*://*.linkedin.com/*"]
    }
  ]
}
